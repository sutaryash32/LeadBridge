{
    "realm": "leadbridge",
    "enabled": true,
    "clients": [
      {
        "clientId": "leadbridge-frontend",
        "enabled": true,
        "publicClient": true,
        "directAccessGrantsEnabled": true,
        "standardFlowEnabled": true,
        "redirectUris": [
          "http://localhost:4200/*"
        ],
        "webOrigins": [
          "http://localhost:4200"
        ]
      }
    ],
    "roles": {
      "realm": [
        {
          "name": "MASTER_MSSP",
          "description": "Master super admin"
        },
        {
          "name": "MSSP",
          "description": "Zone Manager"
        },
        {
          "name": "ENTERPRISE_TENANT",
          "description": "Area Manager"
        }
      ]
    },
    "users": [
      {
        "username": "master",
        "enabled": true,
        "credentials": [
          {
            "type": "password",
            "value": "master",
            "temporary": false
          }
        ],
        "realmRoles": [
          "MASTER_MSSP"
        ]
      },
      {
        "username": "zone",
        "enabled": true,
        "credentials": [
          {
            "type": "password",
            "value": "zone",
            "temporary": false
          }
        ],
        "realmRoles": [
          "MSSP"
        ]
      },
      {
        "username": "area",
        "enabled": true,
        "credentials": [
          {
            "type": "password",
            "value": "area",
            "temporary": false
          }
        ],
        "attributes": {
          "tenantId": [
            "aaaaaaaa-0000-0000-0000-000000000001"
          ]
        },
        "realmRoles": [
          "ENTERPRISE_TENANT"
        ]
      }
    ]
  }
