{
  "realm": "leadbridge",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "accessTokenLifespan": 3600,

  "clients": [
    {
      "clientId": "leadbridge-frontend",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": [
        "http://localhost:4200/*"
      ],
      "webOrigins": [
        "http://localhost:4200"
      ],
      "protocolMappers": [
        {
          "name": "tenantId-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "tenantId",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "tenantId",
            "jsonType.label": "String"
          }
        },
        {
          "name": "msspId-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "msspId",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "msspId",
            "jsonType.label": "String"
          }
        },
        {
          "name": "areaName-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "areaName",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "areaName",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],

  "roles": {
    "realm": [
      {
        "name": "MASTER_MSSP",
        "description": "God-mode — sees all zones, all areas, all leads"
      },
      {
        "name": "MSSP",
        "description": "Zone manager — sees only areas under their zone"
      },
      {
        "name": "ENTERPRISE_TENANT",
        "description": "Area manager — sees only leads in their area"
      }
    ]
  },

